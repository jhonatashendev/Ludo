rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'createdAt', 'coins'])
        && data.keys().size() >= 3
        && data.username is string
        && data.username.size() > 0
        && data.username.size() <= 30
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 100
        && data.createdAt is number
        && data.coins is number;
    }

    // Users Collection
    match /users/{userId} {
      // Create: Owner only
      allow create: if isOwner(userId) && isValidUser(incoming());

      // Read: Owner only (Because of PII - email)
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid; // Dummy list protection, we don't list users.

      // Update: Owner only
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['username', 'coins'])
        && incoming().email == existing().email // immutable
        && incoming().createdAt == existing().createdAt; // immutable
    }
  }
}
